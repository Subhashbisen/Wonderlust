<% layout("layouts/boilerplate") %>

    <body>
        <div class="row mt-3">
            <div class="col-11 col-sm-10 col-md-6 col-lg-4 mx-auto">
                <h3>Create A New Listing</h3>
                <form action="/listings" method="post" class="needs-validation listingForm"
                    enctype="multipart/form-data" novalidate>
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" name="title" placeholder="Enter Title" class="form-control" required>
                        <div class="valid-feedback">
                            "Perfect! Title added successfully."
                        </div>
                        <div class="invalid-feedback">
                            "Please enter a title"
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="description" placeholder="Enter Description" class="form-control"
                            required></textarea>
                        <div class="valid-feedback">
                            "Description added successfully"
                        </div>
                        <div class="invalid-feedback">
                            "Please enter a description"
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">Upload Listing Image</label>
                        <input type="file" name="image" class="form-control" required>
                        <div class="valid-feedback">
                            "Image added successfully."
                        </div>
                        <div class="invalid-feedback">
                            "Please Add A Image"
                        </div>

                    </div>

                    <div class="mb-3">
                        <div class="dropdown">
                            <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1"
                                data-bs-toggle="dropdown" aria-expanded="false">
                                Select Categories
                            </button>
                            <ul class="dropdown-menu p-2" aria-labelledby="dropdownMenuButton1">
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Apartment"
                                            class="form-check-input">
                                        Apartment
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Villa"
                                            class="form-check-input">
                                        Villa
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Farmhouse"
                                            class="form-check-input">
                                        Farmhouse
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Beachfront"
                                            class="form-check-input">
                                        Beachfront
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Mountain"
                                            class="form-check-input">
                                        Mountain View
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="City"
                                            class="form-check-input">
                                        City
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Budget"
                                            class="form-check-input">
                                        Budget
                                    </label>
                                </li>
                                <li class="mb-1">
                                    <label><input type="checkbox" name="categories" value="Luxury"
                                            class="form-check-input">
                                        Luxury
                                    </label>
                                </li>
                            </ul>
                        </div>
                   
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-label">Price</label>
                            <input type="number" name="price" placeholder="Enter Price" class="form-control" required>
                            <div class="valid-feedback">
                                "Price added successfully."
                            </div>
                            <div class="invalid-feedback">
                                "Please enter a price."
                            </div>
                        </div>

                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" name="country" placeholder="Enter Country" class="form-control" required>
                            <div class="valid-feedback">
                                "Country selected successfully."
                            </div>
                            <div class="invalid-feedback">
                                "Please Enter a country."
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" name="location" placeholder="Enter Loction" class="form-control" required>
                        <div class="valid-feedback">
                            "Location added successfully."
                        </div>
                        <div class="invalid-feedback">
                            "Please enter a location."
                        </div>
                    </div>
                    <button class="btn btn-dark add-btn mb-3">Add</button>
                </form>
            </div>
        </div>
    </body>

    