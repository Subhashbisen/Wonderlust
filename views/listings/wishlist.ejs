<% layout("layouts/boilerplate") %>
    <style>
        #filters {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
        }

        .filter {
            text-align: center;
            margin-right: 3rem;
            margin-top: 2rem;
            opacity: 0.7;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 13px;
        }
    </style>

    <body>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 mt-3 g-3">
            <% for( let listing of AllListings) { %>
                <div class="col">
                    <div class="card listing-card">
                        <a href="/listings/<%= listing._id %>" class="listing-links">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                                style="height: 20rem;">
                            <div class="card-img-overlay"></div>
                            <div class="card-body">
                                <p class="card-text">
                                    <b>
                                        <%= listing.title %>
                                    </b> <br>
                                    &#8377 <%= listing.price.toLocaleString("en-IN") %> /Night
                                </p>
                            </div>
                        </a>
                    </div>
                    <button class="wishlist-btn-remove btn btn-dark" data-id="<%= listing._id %>">
                        Remove
                    </button>
                </div>
                <% } %>

        </div>

    </body>